{
  "title": "SupaChat Overview",
  "uid": "supachat-overview",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_requests_total{job=\"supachat-backend\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"supachat-backend\"}[5m]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"supachat.*\"}[1m]) * 100",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "container_memory_usage_bytes{name=~\"supachat.*\"} / 1024 / 1024",
          "legendFormat": "{{name}} MB"
        }
      ]
    },
    {
      "id": 5,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{service=~\"supachat-backend|supachat-frontend\"}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{service=~\"supachat-.*\"} |= \"ERROR\""
        }
      ]
    }
  ]
}
