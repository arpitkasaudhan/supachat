# ── Supabase ──────────────────────────────────────────────────────────────────
# Connection string from: Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Alternative: individual parts (if no full URI)
SUPABASE_DB_HOST=db.<project-ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_db_password

# ── Groq (free) ───────────────────────────────────────────────────────────────
# Sign up free at console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# ── Frontend ──────────────────────────────────────────────────────────────────
# In production this is your EC2 public IP or domain
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme123
